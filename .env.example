# Firebase web app config (Project settings → General → Your apps → SDK setup)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Restrict login to specific emails (comma separated). Empty = allow any Google account.
VITE_ALLOWED_EMAILS=

# Base path for the proxy/analyze endpoints (defaults to same origin during dev via Vite proxy).
# In production set to your deployed Cloudflare Worker URL, e.g. https://api-proxy.example.workers.dev
VITE_WORKER_BASE=
